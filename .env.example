# Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Metered TURN — required for calls across different Wi‑Fi / cities
#
# Option A (best): paste the full iceServers array from Metered → credential → Instructions
# NEXT_PUBLIC_TURN_ICE_SERVERS=[{"urls":"stun:..."},{"urls":"turn:...","username":"...","credential":"..."}]
#
# Option B: username + credential from the same Instructions panel
NEXT_PUBLIC_TURN_USERNAME=your_turn_username
NEXT_PUBLIC_TURN_CREDENTIAL=your_turn_credential
NEXT_PUBLIC_TURN_ICE_SERVERS=[{"urls":"stun:..."},{"urls":"turn:...","username":"...","credential":"..."}]
#
# Option C (optional): fetch iceServers from Metered API (Show API Key next to credential)
# NEXT_PUBLIC_METERED_DOMAIN=yourapp.metered.live
# NEXT_PUBLIC_METERED_TURN_API_KEY=your_api_key
